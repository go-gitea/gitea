{{$pageMeta := .}}
{{$data := .ProjectsData}}
{{$issueProject := NIL}}{{if and $pageMeta.Issue $pageMeta.Issue.Projects}}{{$issueProject = $pageMeta.Issue.Projects}}{{end}}
<div class="divider"></div>
<div class="issue-sidebar-combo sidebar-project-combo" data-selection-mode="multiple" data-update-algo="all"
		{{if $pageMeta.Issue}}data-update-url="{{$pageMeta.RepoLink}}/issues/projects?issue_ids={{$pageMeta.Issue.ID}}"{{end}}
>
	<input class="combo-value" name="project_ids" type="hidden" value="{{SliceUtils.JoinInt64 $data.SelectedProjectIDs}}">
	<div class="ui dropdown full-width {{if not $pageMeta.CanModifyIssueOrPull}}disabled{{end}}">
		<a class="fixed-text muted">
			<strong>{{ctx.Locale.Tr "repo.issues.new.projects"}}</strong> {{if $pageMeta.CanModifyIssueOrPull}}{{svg "octicon-gear"}}{{end}}
		</a>
		<div class="menu">
			{{if or $data.OpenProjects $data.ClosedProjects}}
			<div class="ui icon search input">
				<i class="icon">{{svg "octicon-search" 16}}</i>
				<input type="text" placeholder="{{ctx.Locale.Tr "repo.issues.filter_projects"}}">
			</div>
			{{end}}
			<div class="scrolling menu flex-items-menu">
				<div class="item clear-selection" data-text="">{{ctx.Locale.Tr "repo.issues.new.clear_projects"}}</div>
				<div class="divider"></div>
				{{if $data.OpenProjects}}
					<div class="header">{{ctx.Locale.Tr "repo.issues.new.open_projects"}}</div>
					{{range $data.OpenProjects}}
						<a class="item muted" data-value="{{.ID}}" href="{{.Link ctx}}">
							<span class="item-check-mark">{{svg "octicon-check"}}</span>
							{{svg .IconName 18 "tw-shrink-0"}}<span class="tw-flex-1 tw-break-anywhere">{{.Title}}</span>
						</a>
					{{end}}
				{{end}}
				{{if and $data.OpenProjects $data.ClosedProjects}}<div class="divider"></div>{{end}}
				{{if $data.ClosedProjects}}
					<div class="header">{{ctx.Locale.Tr "repo.issues.new.closed_projects"}}</div>
					{{range $data.ClosedProjects}}
						<a class="item muted" data-value="{{.ID}}" href="{{.Link ctx}}">
							<span class="item-check-mark">{{svg "octicon-check"}}</span>
							{{svg .IconName 18 "tw-shrink-0"}}<span class="tw-flex-1 tw-break-anywhere">{{.Title}}</span>
						</a>
					{{end}}
				{{end}}
			</div>
		</div>
	</div>
	<div class="ui relaxed list muted-links flex-items-block">
		<span class="item empty-list {{if $data.ProjectsWithColumns}}tw-hidden{{end}}">{{ctx.Locale.Tr "repo.issues.new.no_projects"}}</span>
		{{range $data.ProjectsWithColumns}}
			<div class="item tw-flex tw-flex-col tw-items-start">
				<a class="tw-flex tw-items-center tw-gap-2 tw-w-full" href="{{.Project.Link ctx}}">
					{{svg .Project.IconName 18 "tw-shrink-0"}}
					<span class="tw-flex-1 tw-break-anywhere tw-min-w-0">{{.Project.Title}}</span>
				</a>
				{{if .Columns}}
					<div class="text grey" style="padding-left: calc(0.5rem + 18px);">
						<div class="issue-sidebar-combo tw-flex tw-items-center" data-selection-mode="single" data-update-algo="all"
							data-update-url="{{$pageMeta.RepoLink}}/issues/projects/column?issue_id={{$pageMeta.Issue.ID}}&project_id={{.Project.ID}}"
							data-project-id="{{.Project.ID}}">
							<input class="combo-value" name="column_id_{{.Project.ID}}" type="hidden" value="{{if .SelectedColumn}}{{.SelectedColumn.ID}}{{end}}">
							<div class="ui mini compact dropdown muted {{if not $pageMeta.CanModifyIssueOrPull}}disabled{{end}}" {{if not $pageMeta.CanModifyIssueOrPull}}style="padding-right: 0.78571429em;"{{end}}>
								<div class="text" style="text-wrap: wrap;">
									{{if .SelectedColumn}}
										{{if .SelectedColumn.Color}}<span class="color-icon icon-size-8" style="background-color: {{.SelectedColumn.Color}}"></span>{{end}}
										{{.SelectedColumn.Title}}
									{{else}}
										<span class="text grey">{{ctx.Locale.Tr "repo.projects.column"}}</span>
									{{end}}
								</div>
								{{if $pageMeta.CanModifyIssueOrPull}}{{svg "octicon-triangle-down" 14 "tw-shrink-0"}}{{end}}
								<div class="menu">
									{{range .Columns}}
										<a class="item" data-value="{{.ID}}">
											<span class="item-check-mark">{{svg "octicon-check"}}</span>
											{{if .Color}}<span class="color-icon icon-size-8" style="background-color: {{.Color}}"></span>{{end}}
											<span>{{.Title}}</span>
										</a>
									{{end}}
								</div>
							</div>
						</div>
					</div>
				{{end}}
			</div>
		{{end}}
	</div>
</div>
