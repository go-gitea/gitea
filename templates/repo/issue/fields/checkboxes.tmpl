<div class="field {{if not .item.VisibleOnForm}}hidden{{end}}">
	{{template "repo/issue/fields/header" .}}
	{{range $i, $opt := .item.Attributes.options}}
		<div class="field fm-inline">
			<div class="ui checkbox mr-0 {{if and ($opt.visible) (not (SliceUtils.Contains $opt.visible "form"))}}hidden{{end}}">
				<input type="checkbox" name="form-field-{{$.item.ID}}-{{$i}}" {{if $opt.required}}required{{end}}>
				<label>{{ctx.RenderUtils.MarkdownToHtml $opt.label}}</label>
			</div>
			{{if $opt.required}}
				<label class="required"></label>
			{{end}}
		</div>
	{{end}}
</div>
