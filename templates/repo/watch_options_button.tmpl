<a class="ui flex-text-inline tw-ml-1"
	id="repo-watch-{{.RepoID}}"
	data-global-init="initWatchOptions"
	data-repo-link="{{.RepoLink}}"
	data-watch-pull-requests="{{$.WatchPullRequests}}"
	data-watch-issues="{{$.WatchIssues}}"
	data-watch-releases="{{$.WatchReleases}}"
	role="button"
>
	{{svg "octicon-gear"}}
</a>
