<div class="ui labeled button" id="repo-header-watch" {{if not $.IsSigned}}data-tooltip-content="{{ctx.Locale.Tr "repo.watch_guest_user"}}"{{end}}>
	{{$buttonText := ctx.Locale.Tr "repo.watch"}}
	{{if $.IsWatchingRepo}}
		{{$buttonText = ctx.Locale.Tr "repo.watching"}}
	{{end}}
	{{if $.IsSigned}}
		<div class="ui compact small basic floating dropdown button" aria-label="{{$buttonText}}" role="button">
			{{svg "octicon-eye"}}
			<span class="not-mobile" aria-hidden="true">{{$buttonText}}</span>
			{{svg "octicon-triangle-down" 14 "dropdown icon"}}
			{{template "repo/watch_dropdown" dict
				"RepoLink" $.RepoLink
				"IsWatching" $.IsWatchingRepo
				"Watch" $.Watch
			}}
		</div>
	{{else}}
		<a role="button" class="ui compact small basic button" aria-label="{{$buttonText}}" href="{{AppSubUrl}}/user/login">
			{{svg "octicon-eye"}}
			<span class="not-mobile" aria-hidden="true">{{$buttonText}}</span>
		</a>
	{{end}}
	<a class="ui basic label" href="{{$.RepoLink}}/watchers">
		{{CountFmt .Repository.NumWatches}}
	</a>
</div>
