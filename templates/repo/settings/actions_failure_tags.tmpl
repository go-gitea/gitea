{{template "repo/settings/layout_head" (dict "pageClass" "repository settings actions failure-tags")}}
	<div class="repo-setting-content">
		<h4 class="ui top attached header">
			{{ctx.Locale.Tr "actions.failure_tags"}}
		</h4>
		<div class="ui attached segment">
			<p class="text muted">{{ctx.Locale.Tr "actions.failure_tags.description"}}</p>
			<div id="repo-actions-failure-tags"
				data-api-url="{{.FailureTagsAPI}}"
				data-locale-name="{{ctx.Locale.Tr "name"}}"
				data-locale-color="{{ctx.Locale.Tr "actions.failure_tags.color"}}"
				data-locale-description="{{ctx.Locale.Tr "actions.failure_tags.description_field"}}"
				data-locale-add="{{ctx.Locale.Tr "actions.failure_tags.add"}}"
				data-locale-edit="{{ctx.Locale.Tr "edit"}}"
				data-locale-save="{{ctx.Locale.Tr "save"}}"
				data-locale-cancel="{{ctx.Locale.Tr "cancel"}}"
				data-locale-delete="{{ctx.Locale.Tr "delete"}}"
				data-locale-confirm-delete="{{ctx.Locale.Tr "actions.failure_tags.confirm_delete"}}"
			></div>
		</div>
	</div>
{{template "repo/settings/layout_footer" .}}
