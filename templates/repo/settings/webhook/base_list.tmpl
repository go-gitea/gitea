<h4 class="ui top attached header">
	{{.Title}}
	<div class="ui right">
		<div class="ui jump dropdown">
			<div class="ui primary tiny button">{{ctx.Locale.Tr "repo.settings.add_webhook"}}</div>
			{{template "repo/settings/webhook/link_menu" .}}
		</div>
	</div>
</h4>
<div class="ui attached segment">
	<div class="ui list flex-items-block">
		<div class="item"><span>{{.Description}}</span></div>
		{{range .Webhooks}}
			<div class="item">
				<span class="{{if eq .LastStatus 1}}text-green{{else if eq .LastStatus 2}}text-red{{else}}text-text-light{{end}}">{{svg "octicon-dot-fill" 22}}</span>
				<div class="gt-ellipsis flex-1">
					<a title="{{.URL}}" href="{{$.BaseLink}}/{{.ID}}">{{or .Name (ctx.Locale.Tr "repo.settings.webhook.name_empty")}}</a>
					<span class="ml-2 text-grey-light">{{.URL}}</span>
				</div>
				<a class="muted p-2" href="{{$.BaseLink}}/{{.ID}}">{{svg "octicon-pencil"}}</a>
				<a class="text-red p-2 link-action"
					data-url="{{$.Link}}/delete?id={{.ID}}"
					data-modal-confirm="{{ctx.Locale.Tr "repo.settings.webhook_deletion_desc"}}"
				>{{svg "octicon-trash"}}</a>
			</div>
		{{end}}
	</div>
</div>
