{{if eq .HookType "feishu"}}
	<p>
		{{ctx.Locale.Tr "repo.settings.add_web_hook_desc" "https://feishu.cn" (ctx.Locale.Tr "repo.settings.web_hook_name_feishu")}}
		{{ctx.Locale.Tr "repo.settings.add_web_hook_desc" "https://larksuite.com" (ctx.Locale.Tr "repo.settings.web_hook_name_larksuite")}}
	</p>
	<form class="ui form" action="{{.BaseLink}}/feishu/{{or .Webhook.ID "new"}}" method="post">
		{{template "base/disable_form_autofill"}}
		<div class="required field {{if .Err_PayloadURL}}error{{end}}">
			<label for="payload_url">{{ctx.Locale.Tr "repo.settings.payload_url"}}</label>
			<input id="payload_url" name="payload_url" type="url" value="{{.Webhook.URL}}" autofocus required>
		</div>
		<div class="field {{if .Err_AppID}}error{{end}}">
			<label for="app_id">App ID</label>
			<input id="app_id" name="app_id" type="text" value="{{.FeishuHook.AppID}}" required>
		</div>
		<div class="field {{if .Err_AppSecret}}error{{end}}">
			<label for="app_secret">App Secret</label>
			<input id="app_secret" name="app_secret" type="text" value="{{.FeishuHook.AppSecret}}" required>
		</div>
		{{template "repo/settings/webhook/settings" dict "BaseLink" .BaseLink "Webhook" .Webhook}}
	</form>
{{end}}
