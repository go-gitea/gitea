{{template "devtest/devtest-header"}}
<div class="page-content devtest ui container">
	<h1>Severity Colors</h1>

	<h2>Messages</h2>
	<div class="ui error message">
		<div class="header">Error Message</div>
		<p>This is an error message using --color-error-* variables.</p>
	</div>
	<div class="ui warning message">
		<div class="header">Warning Message</div>
		<p>This is a warning message using --color-warning-* variables.</p>
	</div>
	<div class="ui success message">
		<div class="header">Success Message</div>
		<p>This is a success message using --color-success-* variables.</p>
	</div>
	<div class="ui info message">
		<div class="header">Info Message</div>
		<p>This is an info message using --color-info-* variables.</p>
	</div>

	<h2>Form Fields</h2>
	<div class="ui form">
		<div class="field error">
			<label>Error Field</label>
			<input type="text" value="Invalid input" readonly>
		</div>
	</div>

	<h2>Labels</h2>
	<div class="flex-text-block tw-gap-2">
		<div class="ui red label">Red</div>
		<div class="ui orange label">Orange</div>
		<div class="ui yellow label">Yellow</div>
		<div class="ui green label">Green</div>
		<div class="ui blue label">Blue</div>
		<div class="ui violet label">Violet</div>
		<div class="ui purple label">Purple</div>
	</div>

	<h2>Color Swatches</h2>
	<style>
		.color-swatch {
			display: inline-flex;
			flex-direction: column;
			align-items: center;
			gap: 4px;
			min-width: 120px;
		}
		.color-swatch-box {
			width: 100px;
			height: 60px;
			border-radius: 6px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 12px;
		}
	</style>
	<h3>Error</h3>
	<div class="flex-text-block tw-gap-4">
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-error-bg); color: var(--color-error-text); border: 1px solid var(--color-error-border)">Text</div>
			<code>error-bg</code>
		</div>
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-error-bg-hover); color: var(--color-error-text); border: 1px solid var(--color-error-border)">Hover</div>
			<code>error-bg-hover</code>
		</div>
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-error-bg-active); color: var(--color-error-text); border: 1px solid var(--color-error-border)">Active</div>
			<code>error-bg-active</code>
		</div>
	</div>
	<h3>Warning</h3>
	<div class="flex-text-block tw-gap-4">
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-warning-bg); color: var(--color-warning-text); border: 1px solid var(--color-warning-border)">Text</div>
			<code>warning-bg</code>
		</div>
	</div>
	<h3>Success</h3>
	<div class="flex-text-block tw-gap-4">
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-success-bg); color: var(--color-success-text); border: 1px solid var(--color-success-border)">Text</div>
			<code>success-bg</code>
		</div>
	</div>
	<h3>Info</h3>
	<div class="flex-text-block tw-gap-4">
		<div class="color-swatch">
			<div class="color-swatch-box" style="background: var(--color-info-bg); color: var(--color-info-text); border: 1px solid var(--color-info-border)">Text</div>
			<code>info-bg</code>
		</div>
	</div>
</div>
{{template "devtest/devtest-footer"}}
