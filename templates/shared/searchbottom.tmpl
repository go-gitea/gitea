{{if or .result.Language (not .result.UpdatedUnix.IsZero)}}
<div class="ui bottom attached fm-table segment flex-left-right">
		<div class="flex items-center ml-4">
			{{if .result.Language}}
					<i class="color-icon mr-2" style="background-color: {{.result.Color}}"></i>{{.result.Language}}
			{{end}}
		</div>
		<div class="mr-4">
			{{if not .result.UpdatedUnix.IsZero}}
					<span class="ui grey text">{{ctx.Locale.Tr "explore.code_last_indexed_at" (DateUtils.TimeSince .result.UpdatedUnix)}}</span>
			{{end}}
		</div>
</div>
{{end}}
